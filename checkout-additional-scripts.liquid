{% comment %}
Facebook Pixel Purchase Tracking for Shopify Checkout
This code should be added to your checkout.liquid template or through Shopify's Additional Scripts section
{% endcomment %}

{% if first_time_accessed %}
<script>
  // Facebook Pixel Purchase Event Tracking
  {% if checkout.transactions.size > 0 %}
    {% assign transaction = checkout.transactions.first %}
    
    // Prepare content_ids array from line items
    var contentIds = [
      {% for line_item in checkout.line_items %}
        {% if line_item.variant_id %}
          "{{ line_item.variant_id }}"
        {% else %}
          "{{ line_item.product_id }}"
        {% endif %}
        {% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];
    
    // Track the purchase event
    fbq('track', 'Purchase', {
      content_ids: contentIds,
      value: {{ checkout.total_price | times: 0.01 | json }}, // Convert cents to currency
      currency: '{{ checkout.currency }}',
      content_type: 'product',
      num_items: {{ checkout.item_count }},
      content_name: '{{ shop.name | escape }}',
      content_category: 'ecommerce'
    });
    
    // Optional: Track individual products for better attribution
    {% for line_item in checkout.line_items %}
      fbq('trackCustom', 'ProductPurchased', {
        content_id: {% if line_item.variant_id %}"{{ line_item.variant_id }}"{% else %}"{{ line_item.product_id }}"{% endif %},
        content_name: "{{ line_item.title | escape }}",
        content_category: "{{ line_item.product.product_type | escape }}",
        value: {{ line_item.final_price | times: 0.01 | json }},
        currency: '{{ checkout.currency }}',
        quantity: {{ line_item.quantity }}
      });
    {% endfor %}
    
  {% endif %}
</script>
{% endif %}