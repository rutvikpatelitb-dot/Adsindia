@{
    ViewData["Title"] = "Home";
}

<div class="container">
    <div class="row">
        <div class="col-12">
            <div class="text-center mb-5">
                <h1 class="display-4">
                    <i class="fas fa-store"></i> Welcome to CRUD MVC App
                </h1>
                <p class="lead">Complete Product Management System with Full CRUD Operations</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="fas fa-plus-circle fa-3x text-success mb-3"></i>
                    <h5 class="card-title">Create Products</h5>
                    <p class="card-text">Add new products to your inventory with detailed information including name, description, price, and category.</p>
                    <a asp-controller="Products" asp-action="Create" class="btn btn-success">
                        <i class="fas fa-plus"></i> Add Product
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="fas fa-list fa-3x text-primary mb-3"></i>
                    <h5 class="card-title">View Products</h5>
                    <p class="card-text">Browse through all your products with detailed information, search capabilities, and quick access to actions.</p>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-primary">
                        <i class="fas fa-boxes"></i> View Products
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="fas fa-edit fa-3x text-warning mb-3"></i>
                    <h5 class="card-title">Manage Products</h5>
                    <p class="card-text">Update product information, modify prices and stock quantities, or remove products from your inventory.</p>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-warning">
                        <i class="fas fa-cogs"></i> Manage
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4><i class="fas fa-info-circle"></i> Features</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li><i class="fas fa-check text-success"></i> <strong>Create</strong> - Add new products</li>
                                <li><i class="fas fa-check text-success"></i> <strong>Read</strong> - View product details</li>
                                <li><i class="fas fa-check text-success"></i> <strong>Update</strong> - Modify existing products</li>
                                <li><i class="fas fa-check text-success"></i> <strong>Delete</strong> - Remove products</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li><i class="fas fa-check text-success"></i> Form validation</li>
                                <li><i class="fas fa-check text-success"></i> Bootstrap UI</li>
                                <li><i class="fas fa-check text-success"></i> Entity Framework Core</li>
                                <li><i class="fas fa-check text-success"></i> In-Memory Database</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
