@model CrudMvcApp.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h2 class="mb-0">
                        <i class="fas fa-exclamation-triangle"></i> Delete Product
                    </h2>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning" role="alert">
                        <i class="fas fa-exclamation-triangle"></i>
                        <strong>Warning!</strong> Are you sure you want to delete this product? This action cannot be undone.
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <dl class="row">
                                <dt class="col-sm-3 fw-bold">Product Name:</dt>
                                <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

                                <dt class="col-sm-3 fw-bold">Description:</dt>
                                <dd class="col-sm-9">
                                    @if (!string.IsNullOrEmpty(Model.Description))
                                    {
                                        @Html.DisplayFor(model => model.Description)
                                    }
                                    else
                                    {
                                        <em class="text-muted">No description provided</em>
                                    }
                                </dd>

                                <dt class="col-sm-3 fw-bold">Price:</dt>
                                <dd class="col-sm-9">
                                    <span class="text-success fs-5 fw-bold">$@Html.DisplayFor(model => model.Price)</span>
                                </dd>

                                <dt class="col-sm-3 fw-bold">Category:</dt>
                                <dd class="col-sm-9">
                                    <span class="badge bg-primary fs-6">@Html.DisplayFor(model => model.Category)</span>
                                </dd>

                                <dt class="col-sm-3 fw-bold">Stock Quantity:</dt>
                                <dd class="col-sm-9">
                                    <span class="badge fs-6 @(Model.StockQuantity > 10 ? "bg-success" : Model.StockQuantity > 0 ? "bg-warning" : "bg-danger")">
                                        @Html.DisplayFor(model => model.StockQuantity) units
                                    </span>
                                </dd>

                                <dt class="col-sm-3 fw-bold">Created Date:</dt>
                                <dd class="col-sm-9">
                                    <i class="fas fa-calendar-plus text-muted"></i>
                                    @Model.CreatedDate.ToString("dddd, MMMM dd, yyyy 'at' hh:mm tt")
                                </dd>

                                @if (Model.UpdatedDate.HasValue)
                                {
                                    <dt class="col-sm-3 fw-bold">Last Updated:</dt>
                                    <dd class="col-sm-9">
                                        <i class="fas fa-calendar-edit text-muted"></i>
                                        @Model.UpdatedDate?.ToString("dddd, MMMM dd, yyyy 'at' hh:mm tt")
                                    </dd>
                                }
                            </dl>
                        </div>
                    </div>

                    <hr class="my-4">

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary me-md-2">
                                <i class="fas fa-arrow-left"></i> Back to List
                            </a>
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-info me-md-2">
                                <i class="fas fa-eye"></i> View Details
                            </a>
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you absolutely sure you want to delete this product?')">
                                <i class="fas fa-trash"></i> Delete Product
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>